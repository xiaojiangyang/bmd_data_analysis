### MCID and optimal dose (METs-min/ week)

```{r}

val_1pct <- mcid$MCID_1pct[mcid$outcome == "Lumbar BMD"] #Femoral BMD, Hip total BMD
val_2pct <- mcid$MCID_2pct[mcid$outcome == "Lumbar BMD"] #Femoral BMD, Hip total BMD

extract_doses <- function(df, subgroup_name, category_name) {
  
    opt_dose <- df %>%
    arrange(desc(mean)) %>%
    slice(1) %>%
    pull(dose) %>%
    round(0) 
  
  get_mcid_string <- function(threshold) {
    valid_data <- df %>% filter(mean > threshold)
    
    if(nrow(valid_data) == 0) return("na.")
    
    doses <- valid_data %>%
      mutate(abs_diff = abs(mean - threshold)) %>%
      arrange(abs_diff) %>%
      slice(1:2) %>%
      arrange(dose) %>%
      pull(dose) %>%
      round(0) 
    
    if(length(doses) == 1) {
      return(as.character(doses[1]))
    } else {
      gap <- doses[2] - doses[1]
      
      if(gap <= 50) { 
        return(as.character(doses[1]))
      } else {
        return(paste0(doses[1], "~", doses[2]))
      }
    }
  }
  
  tibble(
    Category = category_name,
    Subgroup = subgroup_name,
    `1% MCID` = get_mcid_string(val_1pct),
    `2% MCID` = get_mcid_string(val_2pct),
    Optimal = as.character(opt_dose)
  )
}

