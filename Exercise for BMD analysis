# Converting Effect Sizes into Marginal Effects for Comparison Against Control

In our previous analyses, we demonstrated that the accumulated dose is a crucial factor to consider when implementing a physical activity program. However, what role does the **type** of activity play? Subsequently, we can forecast how the anticipated posterior mean responses fluctuate across the entire spectrum of doses, while also distinguishing between specific interventions.

```{r}

library(janitor)

conditional_effs <- conditional_effects(model_by_treatment)

vs_active_control <- conditional_effs$trt %>% clean_names() %>%
  select(trt, estimate, lower, upper) %>%
  rename(conf.high = upper,
         conf.low = lower)

# add n and k
arm_n_k <- d_bmd %>%
  distinct(studyID, trt, .keep_all = TRUE) %>%
  group_by(trt) %>%
  summarise(n = sum(n),
            k = n())

vs_active_control <- left_join(vs_active_control, arm_n_k, by = "trt")

full_ranks <- netrank(full_pairwise_model, small.values = "bad", method = "SUCRA", nsim = 10000)
full_ranks <- as.data.frame(full_ranks$ranking.random)
full_ranks$trt <- rownames(full_ranks)
full_ranks <- rename(full_ranks,
                     sucra = `full_ranks$ranking.random`)

vs_active_control <- left_join(vs_active_control, full_ranks, by = "trt")

new_levs <- unique(vs_active_control$trt[order(-vs_active_control$estimate)])


vs_active_control %>% filter(trt == "Control")

vs_active_control <- vs_active_control %>%
    mutate(conf.low = conf.low - estimate[trt == "Control"],
         conf.high = conf.high - estimate[trt == "Control"],
         estimate = estimate - estimate[trt == "Control"]) %>%
  filter(trt != "Control")

# Add N
# Add k
# Add exact CI
vs_active_control$gci <- paste(format(round(vs_active_control$estimate,3), nsmall = 2),
      " [", format(round(vs_active_control$conf.low,3), nsmall = 2),
      ", ", format(round(vs_active_control$conf.high,3), nsmall = 2),"]",
      sep = "")

library(ggtext)

vs_active_control_plot <- vs_active_control %>%
  mutate(trt = factor(trt, levels = new_levs)) %>%
  ggplot(aes(x = trt,
             y = estimate,
             ymin = conf.low,
             ymax = conf.high)) +
  geom_pointrange(aes(colour = sucra)) +
  scale_color_continuous("blues") +
  geom_hline(yintercept = 0.02, col = "#8172B2", alpha = 2, linetype = "dashed") +
  geom_hline(yintercept = -0.02, col = "darkgrey", alpha = 0.4) +
  geom_richtext(x = 8, y = 0.03, label = "Minimal Clinically Important Difference", fontface = "italic",
                label.size = NA, colour = "#8172B2", hjust = 1 ) +
  xlab("") +
  ylab("Effect compared with control (MD)") +
  coord_flip(xlim = c(1,16), clip = "off") + plot_theme %+replace%
  theme(plot.margin = margin(5,250,5,5)) +
  geom_text(x = vs_active_control$trt, y = 0.033, label = vs_active_control$gci) +
  geom_text(x = length(vs_active_control$trt)+1, y = 0.033, label = "MD [95% CI]") +
  geom_text(x = vs_active_control$trt, y = 0.047, hjust = 1,
            label = format(vs_active_control$n, big.mark = ",")) +
  geom_text(x = length(vs_active_control$trt)+1, y = 0.046, hjust = 1, label = "n") +
  geom_text(x = vs_active_control$trt, y = 0.05, label = vs_active_control$k) +
  geom_text(x = length(vs_active_control$trt)+1, y = 0.05, label = "k")

ggsave("Figure 3. Converting Effect Sizes into Marginal Effects for Comparison Against Control.pdf",
       vs_active_control_plot,
       dpi = "retina",
       width = 10, height = 4)

write.csv(vs_active_control, "vs_active_control_table.csv", row.names = FALSE)

