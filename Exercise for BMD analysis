d_bmd_mbnma <- d_bmd %>%
  rename_at(c("trt", "weekly_dose", "mean_diff", "md_se"), ~c("agent", "dose", "y", "se")) %>%
  group_by(studyID) %>%
  filter(!any(is.na(dose))) %>%
  ungroup()

network <- mbnma.network(d_bmd_mbnma)
summary(network)

```


#### Perform network meta-Analysis (NMA) and unrelated mean effects (UME) models

```{r}

nma_network <- MBNMAdose::mbnma.run(network, method = "random")
ume_network <- MBNMAdose::mbnma.run(network, method = "random", UME = TRUE)

```


#### Run Emax, spline, and non-parametric models

```{r}

emax <- mbnma.run(network, fun = demax(emax = "rel", ed50 = "rel"), method = "random")
ns <- mbnma.run(network, fun = dspline(type = "ns"), method = "random")
non_param <- mbnma.run(network, fun = dnonparam(direction = "increasing"), method = "random")

