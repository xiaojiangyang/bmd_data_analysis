# Chapter 3: Exercise for Lumbar/Femoral/Hip BMD Analysis

⚠️NOTE: The analytic code is designed to evaluate one specific outcome at a time. The default outcome in the code below is set to "Lumbar BMD". To analyze other outcomes, manually replace "Lumbar BMD" with "Femoral BMD" or "Hip total BMD" in the line below: lines 325, 698, 1537-1538 and 1631.

Guided by Harrer (2021), we are going to fit a Bayesian meta-analysis model using the formula `response | se(se_response) ~ 1 + predictors + (1 | grouping variable)`, where our response variable is the mean difference in BMD, predicted by the weekly energy expenditure (METs-min/week), the length of intervention, and the population characteristics, and maintaining the clusterisation of the effect sizes within studies (`studyID` as grouping variable).

### Creating Pairwise Data and CINeMA Data

First, we are going to filter our data by the outcome of interest (i.e., `Lumbar BMD`).

```{r, message=FALSE, error=FALSE, warning=FALSE, results='hide', echo = FALSE}

d_bmd <- d %>% 
  filter(outcome == "Lumbar BMD") %>% #Femoral BMD, Hip total BMD
  mutate(length = as.numeric(length)) %>% 
  group_by(studyID) %>% 
  filter(length == max(length, na.rm = TRUE)) %>% 
  ungroup()

d_bmd_pooled <- d_bmd %>%
  group_by(studyID) %>%
  filter(n_distinct(trt) > 1) %>%
  ungroup() %>%
  group_by(studyID, trt) %>%
  summarise(
    mean_diff_pooled = sum(n * mean_diff) / sum(n),
    md_se = sqrt(sum((n - 1) * md_se^2 + n * (mean_diff - mean_diff_pooled)^2) / (sum(n) - 1)),
    n = sum(n),
    mean_diff_sd = md_se * sqrt(n),
    overall = first(overall),
    indirectness = first(indirectness),
    .groups = 'drop'
  )%>%
  rename(mean_diff = mean_diff_pooled)

if(!exists("model_by_treatment")){
  model_by_treatment <- brm(mean_diff | se(md_se) ~ 1 + trt + (1 | studyID),
                                   data = d_bmd,
                                   control = list(adapt_delta = 0.99),
                                   cores = 8, chains = 8,
                                   prior = priors, silent = 2)
  saveRDS(model_by_treatment, "model_by_treatment.RDS")
}

conditional_effects <- conditional_effects(model_by_treatment)
active_control_est <- conditional_effects(model_by_treatment)$trt$estimate__[3]

#MCID value
mcid <- d %>%
  mutate(length = as.numeric(length)) %>% 
  group_by(studyID) %>% 
  filter(length == max(length, na.rm = TRUE)) %>% 
  ungroup() %>% 
  filter(outcome %in% c("Femoral BMD", "Lumbar BMD", "Hip total BMD")) %>%
  mutate(
    pre_n = as.numeric(pre_n),
    pre_mean = as.numeric(pre_mean),
    pre_sd = as.numeric(pre_sd)
  ) %>%
  filter(!is.na(pre_n) & !is.na(pre_mean)) %>%
  group_by(outcome) %>%
  summarise(
    Total_Arms = n(),
    Total_Baseline_N = sum(pre_n),
    # BMD: sum(n * pre_mean) / sum(n)
    Pooled_Baseline_Mean = sum(pre_n * pre_mean, na.rm = TRUE) / sum(pre_n, na.rm = TRUE),
    # MCID = 1 or 2% of baseline BMD
    MCID_1pct = 0.01 * Pooled_Baseline_Mean,
    MCID_2pct = 0.02 * Pooled_Baseline_Mean
  ) %>%
  mutate(
    across(where(is.numeric), ~ round(.x, 4))
  )

one_effect_per_arm <- aggregate_effects(d_bmd_pooled)

one_effect_per_arm %>%
  mutate(rob = as.numeric(factor(overall, levels = c("Low", "Some concern", "High")))) %>%
  select(studyID, trt, mean_diff, mean_diff_sd, n, rob, indirectness) %>%
  write.csv(.,
          "one_effect_per_arm.csv")


